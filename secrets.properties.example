# MiaoHub Secrets Configuration
# Copy this file to secrets.properties and fill in your own values.
# DO NOT commit secrets.properties to version control!

# Doubao AI - Get your API key from https://www.volcengine.com/product/doubao
DOUBAO_API_KEY=your_api_key_here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL_ID=your_model_id_here

# Tutu Platform
TUTU_APP_ID=your_app_id_here
TUTU_APP_SECRET=your_app_secret_here
